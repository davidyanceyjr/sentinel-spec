# --------------------------------------------------
# Text normalization
# --------------------------------------------------

* text=auto eol=lf

# --------------------------------------------------
# Markdown
# --------------------------------------------------

*.md text diff=markdown

# --------------------------------------------------
# Shell scripts
# --------------------------------------------------

*.sh text eol=lf

# --------------------------------------------------
# YAML / configs
# --------------------------------------------------

*.yml text
*.yaml text
*.json text
*.toml text

# --------------------------------------------------
# Binary files
# --------------------------------------------------

*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.pdf binary
*.zip binary
*.tar binary
*.tar.gz binary

# --------------------------------------------------
# Prevent diff noise in generated archives
# --------------------------------------------------

*.zip -diff
*.tar -diff
*.tar.gz -diff